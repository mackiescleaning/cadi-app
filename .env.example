# Cadi app — client-side environment variables
#
# Vite bakes every VITE_-prefixed var into the public browser bundle, so ONLY
# public values belong here. Never put a service_role key, Stripe secret key,
# Anthropic key, or any other secret in this file or in any VITE_ var.
#
# Server-side secrets (Stripe secret key, Anthropic, HMRC, GoCardless/TrueLayer
# tokens, Resend, etc.) live on the Supabase Edge Functions and are managed with
# `supabase secrets set` — never here. See CLAUDE.md.

# --- Required ---------------------------------------------------------------
# Supabase project URL and public anon key (both public by design).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Optional ---------------------------------------------------------------
# Public OAuth "Connect" client IDs (identifiers, not secrets). Only needed if
# you run the Stripe / GoCardless payment-connection flows locally; production
# sets these in Vercel.
VITE_STRIPE_CLIENT_ID=
VITE_GOCARDLESS_PAYMENTS_CLIENT_ID=
